{
  "manifest_version": 3,
  "name": "MyUW Plus",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://enroll.wisc.edu/*",
    "https://api.madgrades.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://enroll.wisc.edu/*"],
      "js": ["content.js"]
    }
  ]
}